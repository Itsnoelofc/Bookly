<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found – Bookly</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root[data-theme="light"] {
      --bg: #f7f4ff;
      --bg2: #ede8ff;
      --surface: #ffffff;
      --surface2: #f0ebff;
      --border: #d8cdff;
      --text: #1a0f3a;
      --text2: #5a4a8a;
      --text3: #8a78b8;
      --accent: #6c3de8;
      --accent-soft: #9b6ff5;
      --accent-glow: rgba(108, 61, 232, 0.18);
      --hero-bg: linear-gradient(135deg, #ede8ff 0%, #f7f4ff 60%, #fdf0ff 100%);
      --card-shadow: 0 4px 24px rgba(108, 61, 232, 0.10);
      --nav-bg: rgba(247, 244, 255, 0.88);
    }

    :root[data-theme="dark"] {
      --bg: #0e0a1f;
      --bg2: #150e2e;
      --surface: #1d1538;
      --surface2: #261d47;
      --border: #352a5a;
      --text: #f0ecff;
      --text2: #b8a8e8;
      --text3: #7860b8;
      --accent: #9b6ff5;
      --accent-soft: #c39dff;
      --accent-glow: rgba(155, 111, 245, 0.25);
      --hero-bg: linear-gradient(135deg, #0e0a1f 0%, #150e2e 60%, #1a0a2e 100%);
      --card-shadow: 0 4px 32px rgba(155, 111, 245, 0.15);
      --nav-bg: rgba(14, 10, 31, 0.90);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      transition: background .4s, color .4s;
      overflow-x: hidden;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 0 3rem;
      height: 64px;
      background: var(--nav-bg);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
      transition: background .4s, border-color .4s;
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--accent);
      letter-spacing: -0.5px;
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--text);
    }

    .nav-links {
      display: flex;
      gap: .2rem;
      margin-left: 1rem;
    }

    .nav-links a {
      padding: .4rem 1rem;
      border-radius: 8px;
      font-size: .92rem;
      font-weight: 500;
      color: var(--text2);
      text-decoration: none;
      transition: background .2s, color .2s;
    }

    .nav-links a:hover {
      background: var(--surface2);
      color: var(--accent);
    }

    .nav-search {
      flex: 1;
      max-width: 340px;
      margin-left: auto;
      position: relative;
    }

    .nav-search input {
      width: 100%;
      padding: .5rem 1rem .5rem 2.6rem;
      border-radius: 50px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      transition: border-color .2s, background .4s;
      outline: none;
    }

    .nav-search input:focus {
      border-color: var(--accent);
    }

    .nav-search svg {
      position: absolute;
      left: .8rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text3);
      pointer-events: none;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .btn-ghost {
      padding: .45rem 1.1rem;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 500;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--text);
      cursor: pointer;
      transition: border-color .2s, color .2s;
    }

    .btn-ghost:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .btn-primary {
      padding: .45rem 1.3rem;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      border: none;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      transition: opacity .2s, transform .15s;
    }

    .btn-primary:hover {
      opacity: .88;
      transform: translateY(-1px);
    }

    .theme-toggle {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text2);
      transition: all .2s;
      flex-shrink: 0;
    }

    .theme-toggle:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── 404 MAIN ── */
    .error-page {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 100px 2rem 60px;
      background: var(--hero-bg);
      position: relative;
      overflow: hidden;
      transition: background .4s;
      text-align: center;
    }

    /* Ambient glow blobs */
    .error-page::before {
      content: '';
      position: absolute;
      top: -80px;
      right: -60px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 68%);
      border-radius: 50%;
      pointer-events: none;
    }

    .error-page::after {
      content: '';
      position: absolute;
      bottom: -100px;
      left: -80px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.12) 0%, transparent 68%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* The big illustrated 404 */
    .error-illustration {
      position: relative;
      z-index: 1;
      margin-bottom: 2.5rem;
    }

    .error-number {
      font-family: 'Playfair Display', serif;
      font-size: clamp(7rem, 18vw, 12rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -4px;
      color: var(--accent);
      opacity: .12;
      user-select: none;
      pointer-events: none;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      white-space: nowrap;
    }

    .book-scene {
      position: relative;
      width: 260px;
      height: 200px;
      margin: 0 auto;
    }

    /* Open book SVG stand-in using CSS */
    .open-book {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 200px;
      height: 130px;
    }

    .book-left,
    .book-right {
      position: absolute;
      bottom: 0;
      width: 94px;
      height: 120px;
      border-radius: 4px 0 0 6px;
      background: var(--surface);
      border: 1.5px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .4s, border-color .4s;
    }

    .book-left {
      right: 50%;
      transform-origin: right center;
      transform: perspective(400px) rotateY(22deg);
      border-radius: 4px 0 0 6px;
      box-shadow: -4px 6px 18px var(--accent-glow);
    }

    .book-right {
      left: 50%;
      transform-origin: left center;
      transform: perspective(400px) rotateY(-22deg);
      border-radius: 0 4px 6px 0;
      box-shadow: 4px 6px 18px var(--accent-glow);
    }

    .page-lines {
      display: flex;
      flex-direction: column;
      gap: 7px;
      padding: 12px 10px;
      width: 100%;
    }

    .page-line {
      height: 5px;
      border-radius: 3px;
      background: var(--border);
      opacity: .6;
    }

    .page-line:nth-child(1) {
      width: 80%;
    }

    .page-line:nth-child(2) {
      width: 65%;
    }

    .page-line:nth-child(3) {
      width: 90%;
    }

    .page-line:nth-child(4) {
      width: 55%;
    }

    .page-line:nth-child(5) {
      width: 75%;
    }

    .book-spine {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 14px;
      height: 124px;
      background: var(--accent);
      border-radius: 2px;
      z-index: 2;
      opacity: .7;
    }

    /* Floating question mark */
    .float-q {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 900;
      color: #fff;
      box-shadow: 0 6px 24px var(--accent-glow);
      animation: bob 3s ease-in-out infinite;
      z-index: 3;
    }

    @keyframes bob {

      0%,
      100% {
        transform: translateX(-50%) translateY(0);
      }

      50% {
        transform: translateX(-50%) translateY(-10px);
      }
    }

    /* Text content */
    .error-content {
      position: relative;
      z-index: 1;
      max-width: 480px;
    }

    .error-tag {
      display: inline-block;
      padding: .3rem 1rem;
      border-radius: 50px;
      background: var(--surface2);
      border: 1px solid var(--border);
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .06em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 1.2rem;
    }

    .error-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 900;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: .9rem;
    }

    .error-title em {
      color: var(--accent);
      font-style: italic;
    }

    .error-desc {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text2);
      margin-bottom: 2rem;
    }

    .error-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }

    .btn-hero {
      padding: .8rem 2rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      font-weight: 600;
      border: none;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 6px 24px var(--accent-glow);
      text-decoration: none;
      display: inline-block;
    }

    .btn-hero:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px var(--accent-glow);
    }

    .btn-outline {
      padding: .8rem 2rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      font-weight: 600;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--text2);
      cursor: pointer;
      transition: border-color .2s, color .2s;
      text-decoration: none;
      display: inline-block;
    }

    .btn-outline:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* Quick links */
    .quick-links {
      display: flex;
      gap: .6rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .quick-label {
      font-size: .82rem;
      color: var(--text3);
      margin-bottom: .75rem;
    }

    .quick-pill {
      padding: .4rem 1.1rem;
      border-radius: 50px;
      font-size: .83rem;
      font-weight: 500;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text2);
      text-decoration: none;
      cursor: pointer;
      transition: all .2s;
      display: inline-block;
    }

    .quick-pill:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    /* Wandering book cards — decorative */
    .deco-card {
      position: absolute;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: .6rem .75rem;
      box-shadow: var(--card-shadow);
      font-size: .75rem;
      color: var(--text3);
      pointer-events: none;
      display: flex;
      align-items: center;
      gap: .5rem;
      transition: background .4s, border-color .4s;
    }

    .deco-card .dc-emoji {
      font-size: 1.1rem;
    }

    .deco-card .dc-text {
      font-size: .72rem;
      color: var(--text3);
      line-height: 1.3;
    }

    .deco-card .dc-title {
      font-weight: 700;
      color: var(--text2);
    }

    .deco-card:nth-child(1) {
      top: 18%;
      left: 5%;
      animation: float1 5s ease-in-out infinite;
    }

    .deco-card:nth-child(2) {
      top: 28%;
      right: 4%;
      animation: float2 6s ease-in-out infinite;
    }

    .deco-card:nth-child(3) {
      bottom: 22%;
      left: 7%;
      animation: float1 4.5s ease-in-out infinite reverse;
    }

    @keyframes float1 {

      0%,
      100% {
        transform: translateY(0) rotate(-2deg);
      }

      50% {
        transform: translateY(-10px) rotate(-2deg);
      }
    }

    @keyframes float2 {

      0%,
      100% {
        transform: translateY(0) rotate(2deg);
      }

      50% {
        transform: translateY(-8px) rotate(2deg);
      }
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 3rem;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
      background: var(--bg);
      transition: background .4s, border-color .4s;
    }

    .footer-brand .nav-logo {
      font-size: 1.4rem;
    }

    .footer-tagline {
      font-size: .88rem;
      color: var(--text3);
      margin-top: .5rem;
      line-height: 1.6;
    }

    .footer-col h4 {
      font-size: .85rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: .8rem;
      letter-spacing: .04em;
    }

    .footer-col a {
      display: block;
      font-size: .85rem;
      color: var(--text3);
      text-decoration: none;
      margin-bottom: .5rem;
      transition: color .2s;
    }

    .footer-col a:hover {
      color: var(--accent);
    }

    .footer-bottom {
      border-top: 1px solid var(--border);
      padding: 1.5rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: .8rem;
      color: var(--text3);
      background: var(--bg);
      transition: background .4s;
    }

    @media (max-width: 768px) {
      nav {
        padding: 0 1.25rem;
        gap: 1rem;
      }

      .nav-links {
        display: none;
      }

      .error-page {
        padding: 90px 1.5rem 50px;
      }

      .deco-card {
        display: none;
      }

      footer {
        grid-template-columns: 1fr 1fr;
        padding: 2rem 1.25rem;
      }

      .footer-bottom {
        padding: 1rem 1.25rem;
        flex-direction: column;
        gap: .5rem;
        text-align: center;
      }
    }
  </style>
</head>

<body>

