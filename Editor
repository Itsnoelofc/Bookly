<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bookly – Write Your Story</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>

/* ══ TOKENS ══ */
:root[data-theme="light"] {
  --bg:           #f7f4ff;
  --bg2:          #ede8ff;
  --surface:      #ffffff;
  --surface2:     #f0ebff;
  --border:       #d8cdff;
  --text:         #1a0f3a;
  --text2:        #5a4a8a;
  --text3:        #8a78b8;
  --accent:       #6c3de8;
  --accent-soft:  #9b6ff5;
  --accent-glow:  rgba(108,61,232,0.18);
  --card-shadow:  0 4px 24px rgba(108,61,232,0.10);
  --nav-bg:       rgba(247,244,255,0.92);
  --editor-bg:    #ffffff;
  --editor-border:#e8e0ff;
  --toolbar-bg:   #f7f4ff;
}
:root[data-theme="dark"] {
  --bg:           #0e0a1f;
  --bg2:          #150e2e;
  --surface:      #1d1538;
  --surface2:     #261d47;
  --border:       #352a5a;
  --text:         #f0ecff;
  --text2:        #b8a8e8;
  --text3:        #7860b8;
  --accent:       #9b6ff5;
  --accent-soft:  #c39dff;
  --accent-glow:  rgba(155,111,245,0.25);
  --card-shadow:  0 4px 32px rgba(155,111,245,0.15);
  --nav-bg:       rgba(14,10,31,0.92);
  --editor-bg:    #1a1530;
  --editor-border:#2e2355;
  --toolbar-bg:   #150e2e;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { height: 100%; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  transition: background .4s, color .4s;
  overflow-x: hidden;
}

/* ══ NAV ══ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; align-items: center; gap: 1.5rem;
  padding: 0 2rem; height: 60px;
  background: var(--nav-bg);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  transition: background .4s, border-color .4s;
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem; font-weight: 900;
  color: var(--accent); letter-spacing: -.5px; text-decoration: none; flex-shrink: 0;
}
.nav-logo span { color: var(--text); }

.nav-story-title {
  flex: 1; max-width: 340px;
  font-size: .92rem; font-weight: 600; color: var(--text2);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.nav-story-title em { color: var(--text3); font-style: normal; font-size: .8rem; margin-left: .4rem; }

.save-indicator {
  display: flex; align-items: center; gap: .35rem;
  font-size: .78rem; color: var(--text3); flex-shrink: 0;
}
.save-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--text3); transition: background .3s;
}
.save-dot.saved { background: #34d399; }
.save-dot.saving { background: #fbbf24; animation: pulse 1s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

.nav-right { display: flex; align-items: center; gap: .6rem; margin-left: auto; }
.nav-btn-sm {
  padding: .38rem 1rem; border-radius: 8px;
  font-family: 'DM Sans', sans-serif; font-size: .85rem; font-weight: 600;
  border: 1.5px solid var(--border); background: transparent; color: var(--text2);
  cursor: pointer; transition: all .2s;
}
.nav-btn-sm:hover { border-color: var(--accent); color: var(--accent); }
.btn-publish {
  padding: .42rem 1.3rem; border-radius: 8px;
  font-family: 'DM Sans', sans-serif; font-size: .85rem; font-weight: 700;
  border: none; background: var(--accent); color: #fff;
  cursor: pointer; transition: opacity .2s, transform .15s;
  box-shadow: 0 3px 12px var(--accent-glow);
  display: flex; align-items: center; gap: .4rem;
}
.btn-publish:hover { opacity: .88; transform: translateY(-1px); }
.theme-toggle {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid var(--border); background: var(--surface2);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text2); transition: all .2s;
}
.theme-toggle:hover { border-color: var(--accent); color: var(--accent); }

/* ══ LAYOUT ══ */
.writer-wrap {
  display: flex;
  height: calc(100vh - 60px);
  margin-top: 60px;
}

/* ══ LEFT PANEL – Chapter list ══ */
.left-panel {
  width: 260px; flex-shrink: 0;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  transition: background .4s, border-color .4s, width .3s;
  overflow: hidden;
}
.left-panel.collapsed { width: 0; border-right: none; }

.lp-header {
  padding: 1rem 1.2rem .8rem;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
}
.lp-title { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text3); }
.lp-add {
  width: 26px; height: 26px; border-radius: 6px;
  border: 1.5px solid var(--border); background: var(--surface2);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text3); font-size: 1rem; line-height: 1;
  transition: all .2s;
}
.lp-add:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }

.chapter-list { flex: 1; overflow-y: auto; padding: .5rem 0; }
.chapter-list::-webkit-scrollbar { width: 3px; }
.chapter-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

.ch-item {
  display: flex; align-items: center; gap: .6rem;
  padding: .6rem 1.2rem; cursor: pointer;
  transition: background .15s;
  position: relative;
}
.ch-item:hover { background: var(--surface2); }
.ch-item.active { background: var(--accent-glow); }
.ch-item.active .ch-name { color: var(--accent); font-weight: 600; }
.ch-drag { color: var(--text3); opacity: .4; flex-shrink: 0; cursor: grab; font-size: .7rem; }
.ch-num-b {
  width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
  background: var(--surface2); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: .68rem; font-weight: 700; color: var(--text3);
  transition: background .2s;
}
.ch-item.active .ch-num-b { background: var(--accent); border-color: var(--accent); color: #fff; }
.ch-name { flex: 1; font-size: .84rem; color: var(--text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ch-words { font-size: .68rem; color: var(--text3); flex-shrink: 0; }
.ch-dot { width: 6px; height: 6px; border-radius: 50%; background: #fbbf24; flex-shrink: 0; }
.ch-dot.published { background: #34d399; }

.lp-story-info {
  padding: .9rem 1.2rem;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
.lp-cover-mini {
  width: 100%; height: 100px; border-radius: 10px;
  background: linear-gradient(145deg,#6c3de8,#a855f7,#ec4899);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; margin-bottom: .7rem; cursor: pointer;
  transition: opacity .2s; position: relative; overflow: hidden;
}
.lp-cover-mini:hover::after {
  content: '✏️ Edit cover';
  position: absolute; inset: 0;
  background: rgba(0,0,0,.55);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: .78rem; font-weight: 600; font-family: 'DM Sans', sans-serif;
}
.lp-story-name { font-size: .85rem; font-weight: 700; color: var(--text); margin-bottom: .15rem; }
.lp-story-meta { font-size: .72rem; color: var(--text3); }

/* ══ CENTRE – Editor ══ */
.editor-area {
  flex: 1; display: flex; flex-direction: column;
  overflow: hidden; background: var(--bg);
  transition: background .4s;
}

/* Toolbar */
.toolbar {
  background: var(--toolbar-bg);
  border-bottom: 1px solid var(--border);
  padding: .45rem 1.5rem;
  display: flex; align-items: center; gap: .25rem;
  flex-wrap: wrap; flex-shrink: 0;
  transition: background .4s, border-color .4s;
}
.toolbar-sep { width: 1px; height: 20px; background: var(--border); margin: 0 .3rem; }
.tb-btn {
  width: 32px; height: 32px; border-radius: 7px;
  border: none; background: transparent;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text2);
  font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600;
  transition: background .15s, color .15s;
}
.tb-btn:hover { background: var(--surface2); color: var(--accent); }
.tb-btn.active { background: var(--accent-glow); color: var(--accent); }
.tb-btn.bold { font-weight: 900; font-size: .9rem; }
.tb-btn.italic { font-style: italic; font-family: 'Lora', serif; }
.tb-select {
  padding: .28rem .6rem; border-radius: 7px;
  border: 1px solid var(--border); background: var(--surface);
  color: var(--text2); font-family: 'DM Sans', sans-serif; font-size: .8rem;
  cursor: pointer; outline: none; transition: border-color .2s;
}
.tb-select:focus { border-color: var(--accent); }
.toolbar-right { margin-left: auto; display: flex; align-items: center; gap: .5rem; }
.word-count { font-size: .75rem; color: var(--text3); }

/* Chapter title bar */
.chapter-title-bar {
  padding: 1.2rem 3rem .6rem;
  background: var(--editor-bg);
  border-bottom: 1px solid var(--editor-border);
  display: flex; align-items: center; gap: .8rem;
  flex-shrink: 0;
  transition: background .4s, border-color .4s;
}
.ch-label { font-size: .75rem; color: var(--text3); font-weight: 600; flex-shrink: 0; }
.ch-title-input {
  flex: 1;
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem; font-weight: 700;
  border: none; background: transparent; color: var(--text);
  outline: none;
}
.ch-title-input::placeholder { color: var(--text3); }

/* Editor scroll container */
.editor-scroll {
  flex: 1; overflow-y: auto; background: var(--bg);
  transition: background .4s;
}
.editor-scroll::-webkit-scrollbar { width: 5px; }
.editor-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* The actual editable area */
.editor-page {
  max-width: 740px; margin: 2.5rem auto 6rem;
  background: var(--editor-bg);
  border: 1px solid var(--editor-border);
  border-radius: 16px;
  padding: 3rem 4rem;
  box-shadow: var(--card-shadow);
  min-height: 500px;
  transition: background .4s, border-color .4s, box-shadow .4s;
}
.editor-content {
  font-family: 'Lora', Georgia, serif;
  font-size: 1.05rem; line-height: 2;
  color: var(--text);
  min-height: 420px; outline: none;
  caret-color: var(--accent);
}
.editor-content:empty::before {
  content: attr(data-placeholder);
  color: var(--text3); pointer-events: none;
  font-style: italic;
}
.editor-content p { margin-bottom: .8em; }
.editor-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem; font-weight: 800;
  margin: 1.2em 0 .5em; color: var(--text);
}
.editor-content h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem; font-weight: 700;
  margin: 1em 0 .4em; color: var(--text);
}
.editor-content blockquote {
  border-left: 3px solid var(--accent);
  margin: 1em 0; padding: .5em 1.2em;
  color: var(--text2); font-style: italic;
  background: var(--surface2); border-radius: 0 8px 8px 0;
}

/* Floating action bar (context menu substitute) */
.float-bar {
  position: fixed; z-index: 300;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px; padding: .3rem .4rem;
  display: none; gap: .2rem;
  box-shadow: var(--card-shadow);
  animation: floatIn .15s ease;
}
.float-bar.show { display: flex; }
@keyframes floatIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:none; } }
.fb-btn {
  width: 30px; height: 30px; border-radius: 6px; border: none;
  background: transparent; color: var(--text2); cursor: pointer;
  font-size: .8rem; font-weight: 700; display: flex; align-items: center; justify-content: center;
  transition: background .15s, color .15s;
}
.fb-btn:hover { background: var(--surface2); color: var(--accent); }

/* ══ RIGHT PANEL – Story settings ══ */
.right-panel {
  width: 300px; flex-shrink: 0;
  background: var(--surface);
  border-left: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow-y: auto; overflow-x: hidden;
  transition: background .4s, border-color .4s, width .3s;
}
.right-panel::-webkit-scrollbar { width: 3px; }
.right-panel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
.right-panel.collapsed { width: 0; border-left: none; }

.rp-section {
  padding: 1.1rem 1.3rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.rp-title { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text3); margin-bottom: .9rem; }

/* Cover uploader */
.cover-upload {
  width: 100%; aspect-ratio: 2/3;
  border-radius: 12px; border: 2px dashed var(--border);
  background: var(--surface2);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: .5rem; cursor: pointer; transition: all .2s;
  position: relative; overflow: hidden;
}
.cover-upload:hover { border-color: var(--accent); background: var(--accent-glow); }
.cover-preview {
  position: absolute; inset: 0;
  background: linear-gradient(145deg,#6c3de8,#a855f7,#ec4899);
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem;
}
.cover-preview-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,.5);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity .2s;
  font-size: .82rem; color: #fff; font-weight: 600; gap: .3rem;
}
.cover-upload:hover .cover-preview-overlay { opacity: 1; }
.cu-icon { font-size: 1.8rem; color: var(--text3); }
.cu-label { font-size: .82rem; font-weight: 600; color: var(--text2); }
.cu-hint { font-size: .72rem; color: var(--text3); }

/* Form fields */
.rp-field { margin-bottom: .9rem; }
.rp-label { font-size: .78rem; font-weight: 600; color: var(--text2); margin-bottom: .35rem; display: block; }
.rp-input {
  width: 100%; padding: .6rem .8rem;
  border-radius: 9px; border: 1.5px solid var(--border);
  background: var(--surface2); color: var(--text);
  font-family: 'DM Sans', sans-serif; font-size: .85rem;
  outline: none; transition: border-color .2s;
}
.rp-input:focus { border-color: var(--accent); }
.rp-input::placeholder { color: var(--text3); }
textarea.rp-input { resize: vertical; min-height: 80px; line-height: 1.6; }
.rp-select {
  width: 100%; padding: .6rem .8rem;
  border-radius: 9px; border: 1.5px solid var(--border);
  background: var(--surface2); color: var(--text);
  font-family: 'DM Sans', sans-serif; font-size: .85rem;
  outline: none; cursor: pointer; transition: border-color .2s;
}
.rp-select:focus { border-color: var(--accent); }

/* Tag input */
.tag-input-wrap {
  display: flex; flex-wrap: wrap; gap: .35rem;
  padding: .5rem .7rem; border-radius: 9px;
  border: 1.5px solid var(--border); background: var(--surface2);
  min-height: 40px; cursor: text; transition: border-color .2s;
}
.tag-input-wrap:focus-within { border-color: var(--accent); }
.tag-chip {
  display: flex; align-items: center; gap: .25rem;
  padding: .18rem .6rem; border-radius: 50px;
  background: var(--accent-glow); color: var(--accent);
  font-size: .74rem; font-weight: 600; white-space: nowrap;
}
.tag-remove { cursor: pointer; opacity: .6; transition: opacity .15s; font-size: .8rem; line-height: 1; }
.tag-remove:hover { opacity: 1; }
.tag-text-input {
  border: none; background: transparent; outline: none;
  font-family: 'DM Sans', sans-serif; font-size: .82rem; color: var(--text);
  min-width: 80px; flex: 1;
}
.tag-text-input::placeholder { color: var(--text3); }

/* Toggle switch */
.toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: .7rem;
}
.toggle-lbl { font-size: .83rem; color: var(--text2); }
.toggle-switch {
  width: 36px; height: 20px; border-radius: 50px;
  background: var(--border); cursor: pointer; position: relative;
  transition: background .25s;
}
.toggle-switch.on { background: var(--accent); }
.toggle-switch::after {
  content: ''; position: absolute;
  width: 14px; height: 14px; border-radius: 50%; background: #fff;
  top: 3px; left: 3px; transition: left .25s;
  box-shadow: 0 1px 3px rgba(0,0,0,.2);
}
.toggle-switch.on::after { left: 19px; }

/* Publish btn in panel */
.btn-publish-full {
  width: 100%; padding: .75rem;
  border-radius: 11px; border: none;
  background: var(--accent); color: #fff;
  font-family: 'DM Sans', sans-serif; font-size: .95rem; font-weight: 700;
  cursor: pointer; box-shadow: 0 4px 16px var(--accent-glow);
  transition: opacity .2s, transform .2s;
  display: flex; align-items: center; justify-content: center; gap: .5rem;
}
.btn-publish-full:hover { opacity: .88; transform: translateY(-1px); }
.btn-save-draft {
  width: 100%; padding: .65rem; margin-bottom: .6rem;
  border-radius: 11px;
  border: 1.5px solid var(--border); background: var(--surface2);
  font-family: 'DM Sans', sans-serif; font-size: .88rem; font-weight: 600;
  color: var(--text2); cursor: pointer; transition: all .2s;
}
.btn-save-draft:hover { border-color: var(--accent); color: var(--accent); }

/* ══ PUBLISH MODAL ══ */
.modal-overlay {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(0,0,0,.55); backdrop-filter: blur(6px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity .3s;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 22px; padding: 2.2rem;
  max-width: 480px; width: 90%;
  box-shadow: 0 24px 80px rgba(0,0,0,.3);
  transform: scale(.95) translateY(20px);
  transition: transform .3s, opacity .3s;
}
.modal-overlay.open .modal { transform: none; }
.modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem; font-weight: 900; color: var(--text);
  margin-bottom: .4rem;
}
.modal-sub { font-size: .88rem; color: var(--text3); margin-bottom: 1.5rem; }
.modal-checklist { display: flex; flex-direction: column; gap: .7rem; margin-bottom: 1.5rem; }
.mc-item {
  display: flex; align-items: center; gap: .7rem;
  padding: .7rem .9rem; border-radius: 10px;
  background: var(--surface2); border: 1px solid var(--border);
}
.mc-icon { font-size: 1.1rem; }
.mc-text { flex: 1; font-size: .85rem; color: var(--text2); }
.mc-check { font-size: .9rem; }
.mc-item.ok { border-color: rgba(52,211,153,.3); }
.mc-item.ok .mc-check { color: #34d399; }
.mc-item.warn { border-color: rgba(251,191,36,.3); }
.mc-item.warn .mc-check { color: #fbbf24; }
.modal-actions { display: flex; gap: .7rem; }
.modal-cancel {
  flex: 1; padding: .72rem; border-radius: 10px;
  border: 1.5px solid var(--border); background: transparent;
  font-family: 'DM Sans', sans-serif; font-size: .9rem; font-weight: 600;
  color: var(--text2); cursor: pointer; transition: all .2s;
}
.modal-cancel:hover { border-color: var(--accent); color: var(--accent); }
.modal-confirm {
  flex: 2; padding: .72rem; border-radius: 10px;
  border: none; background: var(--accent); color: #fff;
  font-family: 'DM Sans', sans-serif; font-size: .9rem; font-weight: 700;
  cursor: pointer; box-shadow: 0 3px 14px var(--accent-glow);
  transition: opacity .2s, transform .15s;
  display: flex; align-items: center; justify-content: center; gap: .4rem;
}
.modal-confirm:hover { opacity: .88; transform: translateY(-1px); }

/* ══ SUCCESS TOAST ══ */
.toast {
  position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(80px);
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 50px; padding: .7rem 1.4rem;
  display: flex; align-items: center; gap: .7rem;
  box-shadow: var(--card-shadow); z-index: 600;
  font-size: .88rem; font-weight: 600; color: var(--text);
  transition: transform .4s cubic-bezier(.22,1,.36,1), opacity .4s;
  opacity: 0;
}
.toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.toast-icon { font-size: 1.1rem; }

/* ══ FOOTER ══ */
footer {
  border-top: 1px solid var(--border);
  padding: 3rem;
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem;
  background: var(--bg); transition: background .4s, border-color .4s;
}
.footer-brand .nav-logo { font-size: 1.4rem; }
.footer-tagline { font-size: .88rem; color: var(--text3); margin-top: .5rem; line-height: 1.6; }
