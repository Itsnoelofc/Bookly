<script>
/* ══ THEME ══ */
function toggleTheme() {
  const html = document.documentElement;
  const dark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', dark ? 'light' : 'dark');
  document.getElementById('theme-icon').innerHTML = dark
    ? `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`
    : `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
}

/* ══ EDITOR FORMATTING ══ */
function fmt(cmd) {
  document.getElementById('editor').focus();
  document.execCommand(cmd, false, null);
}

function insertSceneBreak() {
  document.getElementById('editor').focus();
  document.execCommand('insertHTML', false,
    '<p style="text-align:center;color:var(--text3);letter-spacing:.3em;margin:1.5em 0;">✦ ✦ ✦</p><p></p>');
}

function applyBlock(val) {
  document.getElementById('editor').focus();
  document.execCommand('formatBlock', false, val);
}

function wrapQuote() {
  document.getElementById('editor').focus();
  document.execCommand('formatBlock', false, 'blockquote');
}

/* Word count */
function countWords(text) {
  return text.trim() ? text.trim().split(/\s+/).length : 0;
}

const editor = document.getElementById('editor');
editor.addEventListener('input', () => {
  const words = countWords(editor.innerText);
  document.getElementById('word-count').textContent = words.toLocaleString() + ' word' + (words !== 1 ? 's' : '');
  triggerSave();
  updateModal();
});

/* ══ SAVE INDICATOR ══ */
let saveTimer;
function triggerSave() {
  const dot = document.getElementById('save-dot');
  const txt = document.getElementById('save-text');
  dot.className = 'save-dot saving';
  txt.textContent = 'Saving…';
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    dot.className = 'save-dot saved';
    txt.textContent = 'Saved';
  }, 1400);
}

/* ══ CHAPTER TITLE ══ */
function onChapterTitleChange() {
  const title = document.getElementById('ch-title').value || 'Untitled';
  document.getElementById('nav-title').innerHTML = 'Midnight Orchid <em>· ' + title + '</em>';
  triggerSave();
}

/* ══ CHAPTER LIST ══ */
let chapterCount = 9;
function selectChapter(el, num) {
  document.querySelectorAll('.ch-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
}
function addChapter() {
  chapterCount++;
  const list = document.getElementById('chapter-list');
  const div = document.createElement('div');
  div.className = 'ch-item active';
  div.onclick = function() { selectChapter(this, chapterCount); };
  div.innerHTML = `
    <span class="ch-drag">⠿</span>
    <div class="ch-num-b">${chapterCount}</div>
    <span class="ch-name">Chapter ${chapterCount}</span>
    <span class="ch-dot"></span>`;
  document.querySelectorAll('.ch-item').forEach(i => i.classList.remove('active'));
  list.appendChild(div);
  div.scrollIntoView({ behavior: 'smooth' });
  document.getElementById('ch-title').value = '';
  document.getElementById('ch-title').placeholder = 'Chapter ' + chapterCount + ' title…';
  editor.innerHTML = '';
  editor.focus();
  document.getElementById('word-count').textContent = '0 words';
  showToast('✨', 'New chapter created!');
}

/* ══ TAGS ══ */
function addTag(e) {
  if (e.key !== 'Enter') return;
  const input = document.getElementById('tag-text');
  const val = input.value.trim().toLowerCase().replace(/\s+/g, '-');
  if (!val) return;
  const wrap = document.getElementById('tag-wrap');
  const chip = document.createElement('span');
  chip.className = 'tag-chip';
  chip.innerHTML = `${val} <span class="tag-remove" onclick="removeTag(this)">×</span>`;
  wrap.insertBefore(chip, input);
  input.value = '';
}
function removeTag(btn) {
  btn.parentElement.remove();
}

/* ══ COVER ══ */
function triggerCoverUpload() {
  document.getElementById('cover-input').click();
}
function handleCover(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const preview = document.querySelector('.cover-preview');
    preview.style.backgroundImage = `url(${e.target.result})`;
    preview.style.backgroundSize = 'cover';
    preview.style.backgroundPosition = 'center';
    preview.textContent = '';
    showToast('🖼️', 'Cover updated!');
  };
  reader.readAsDataURL(input.files[0]);
}

/* ══ FLOATING BAR ON SELECTION ══ */
document.addEventListener('mouseup', e => {
  const sel = window.getSelection();
  const bar = document.getElementById('float-bar');
  if (sel && sel.toString().trim() && editor.contains(sel.anchorNode)) {
    const r = sel.getRangeAt(0).getBoundingClientRect();
    bar.style.top = (r.top + window.scrollY - 46) + 'px';
    bar.style.left = Math.max(8, r.left + r.width / 2 - 70) + 'px';
    bar.classList.add('show');
  } else {
    setTimeout(() => bar.classList.remove('show'), 200);
  }
});

/* ══ KEYBOARD SHORTCUTS ══ */
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 's') {
    e.preventDefault(); triggerSave();
    showToast('💾', 'Draft saved!');
  }
});

/* ══ DRAFT SAVE ══ */
function saveDraft() {
  triggerSave();
  showToast('💾', 'Draft saved!');
}

/* ══ PREVIEW ══ */
function previewStory() {
  window.open('bookly-reader.html', '_blank');
}

/* ══ PUBLISH MODAL ══ */
function updateModal() {
  const words = countWords(editor.innerText);
  const item = document.getElementById('content-check');
  const txt  = document.getElementById('content-check-text');
  const icon = document.getElementById('content-check-icon');
  txt.textContent = `Chapter content (${words.toLocaleString()} words)`;
  if (words >= 100) {
    item.classList.add('ok'); item.classList.remove('warn');
    icon.textContent = '✓';
  } else if (words > 0) {
    item.classList.add('warn'); item.classList.remove('ok');
    icon.textContent = '⚠';
  } else {
    item.classList.remove('ok','warn');
    icon.textContent = '○';
  }
}

function openPublish() {
  updateModal();
  document.getElementById('publish-modal').classList.add('open');
}
function closePublish() {
  document.getElementById('publish-modal').classList.remove('open');
}
function closePublishOutside(e) {
  if (e.target === document.getElementById('publish-modal')) closePublish();
}
function publishChapter() {
  const btn = document.getElementById('modal-confirm-btn');
  btn.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="animation:spin .7s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Publishing…';
  btn.style.opacity = '.7';
  const style = document.createElement('style');
  style.textContent = '@keyframes spin { to { transform:rotate(360deg); } }';
  document.head.appendChild(style);
  setTimeout(() => {
    closePublish();
    // Mark chapter as published in list
    const active = document.querySelector('.ch-item.active .ch-dot');
    if (active) active.classList.add('published');
    showToast('🎉', 'Chapter published! Your readers are notified.');
    btn.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 2 11 13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Publish now';
    btn.style.opacity = '1';
  }, 1800);
}

/* ══ TOAST ══ */
let toastTimer;
function showToast(icon, msg) {
  const t = document.getElementById('toast');
  document.querySelector('.toast-icon').textContent = icon;
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

/* Init */
updateModal();
editor.focus();
</script>
