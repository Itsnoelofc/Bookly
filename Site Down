<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>We'll Be Right Back – Bookly</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root[data-theme="light"] {
      --bg: #f7f4ff;
      --bg2: #ede8ff;
      --surface: #ffffff;
      --surface2: #f0ebff;
      --border: #d8cdff;
      --text: #1a0f3a;
      --text2: #5a4a8a;
      --text3: #8a78b8;
      --accent: #6c3de8;
      --accent-soft: #9b6ff5;
      --accent-glow: rgba(108, 61, 232, 0.18);
      --card-shadow: 0 4px 24px rgba(108, 61, 232, 0.10);
    }

    :root[data-theme="dark"] {
      --bg: #0e0a1f;
      --bg2: #150e2e;
      --surface: #1d1538;
      --surface2: #261d47;
      --border: #352a5a;
      --text: #f0ecff;
      --text2: #b8a8e8;
      --text3: #7860b8;
      --accent: #9b6ff5;
      --accent-soft: #c39dff;
      --accent-glow: rgba(155, 111, 245, 0.25);
      --card-shadow: 0 4px 32px rgba(155, 111, 245, 0.15);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      transition: background .4s, color .4s;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* ── TOP BAR (minimal — no nav links during maintenance) ── */
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 64px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      transition: background .4s, border-color .4s;
      position: relative;
      z-index: 10;
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--accent);
      letter-spacing: -0.5px;
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--text);
    }

    .theme-toggle {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text2);
      transition: all .2s;
      flex-shrink: 0;
    }

    .theme-toggle:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── MAIN ── */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    /* Background glow blobs */
    main::before {
      content: '';
      position: absolute;
      top: -100px;
      right: -80px;
      width: 620px;
      height: 620px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 65%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    main::after {
      content: '';
      position: absolute;
      bottom: -80px;
      left: -100px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(168, 85, 247, .1) 0%, transparent 65%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .content {
      position: relative;
      z-index: 1;
      max-width: 560px;
      width: 100%;
    }

    /* ── ANIMATED GEAR / BOOK ICON ── */
    .illustration {
      margin: 0 auto 2.5rem;
      width: 130px;
      height: 130px;
      position: relative;
    }

    /* Outer ring — spins */
    .ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 3px dashed var(--border);
      animation: spin 18s linear infinite;
      transition: border-color .4s;
    }

    /* Orbit dot */
    .orbit-dot {
      position: absolute;
      top: -5px;
      left: 50%;
      transform: translateX(-50%);
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    @keyframes spin {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    /* Inner circle — the book face */
    .inner-circle {
      position: absolute;
      inset: 14px;
      border-radius: 50%;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.8rem;
      transition: background .4s, border-color .4s;
    }

    /* Wrench badge on inner circle */
    .wrench-badge {
      position: absolute;
      bottom: 10px;
      right: 8px;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .9rem;
      border: 2px solid var(--bg);
      transition: border-color .4s;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 var(--accent-glow);
      }

      50% {
        box-shadow: 0 0 0 7px transparent;
      }
    }

    /* ── TAG ── */
    .maint-tag {
      display: inline-block;
      padding: .3rem 1rem;
      border-radius: 50px;
      background: var(--surface2);
      border: 1px solid var(--border);
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .07em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 1.2rem;
    }

    /* ── HEADING ── */
    .maint-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      line-height: 1.18;
      color: var(--text);
      margin-bottom: .9rem;
    }

    .maint-title em {
      color: var(--accent);
      font-style: italic;
    }

    .maint-desc {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text2);
      margin-bottom: 2.5rem;
    }

    /* ── COUNTDOWN ── */
    .countdown-wrap {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }

    .countdown-unit {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: .9rem 1.2rem;
      min-width: 76px;
      box-shadow: var(--card-shadow);
      transition: background .4s, border-color .4s;
    }

    .countdown-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 900;
      color: var(--accent);
      display: block;
      line-height: 1;
    }

    .countdown-lbl {
      font-size: .68rem;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--text3);
      margin-top: .3rem;
      display: block;
    }

    /* ── PROGRESS BAR ── */
    .progress-section {
      margin-bottom: 2.5rem;
    }

    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: .55rem;
    }

    .progress-label {
      font-size: .82rem;
      font-weight: 600;
      color: var(--text2);
    }

    .progress-pct {
      font-size: .82rem;
      font-weight: 700;
      color: var(--accent);
    }

    .progress-track {
      height: 8px;
      border-radius: 50px;
      background: var(--surface2);
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .progress-fill {
      height: 100%;
      border-radius: 50px;
      background: linear-gradient(90deg, var(--accent), var(--accent-soft));
      width: 0%;
      transition: width 1.6s cubic-bezier(.4, 0, .2, 1);
    }

    /* ── NOTIFY FORM ── */
    .notify-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 1.5rem;
      box-shadow: var(--card-shadow);
      margin-bottom: 2rem;
      transition: background .4s, border-color .4s;
    }

    .notify-label {
      font-size: .88rem;
      font-weight: 600;
      color: var(--text2);
      margin-bottom: .85rem;
      display: block;
    }

    .notify-row {
      display: flex;
      gap: .6rem;
    }

    .notify-input {
      flex: 1;
      padding: .6rem 1.1rem;
      border-radius: 50px;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      outline: none;
      transition: border-color .2s, background .4s;
    }

    .notify-input:focus {
      border-color: var(--accent);
    }

    .notify-input::placeholder {
      color: var(--text3);
    }

    .btn-notify {
      padding: .6rem 1.4rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: .88rem;
      font-weight: 600;
      border: none;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      transition: opacity .2s, transform .15s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .btn-notify:hover {
      opacity: .88;
      transform: translateY(-1px);
    }

    .notify-success {
      display: none;
      font-size: .85rem;
      color: #059669;
      font-weight: 600;
      margin-top: .75rem;
    }

    /* ── STATUS CHECKLIST ── */
    .status-list {
      display: flex;
      flex-direction: column;
      gap: .55rem;
      margin-bottom: 2rem;
      text-align: left;
    }

    .status-item {
      display: flex;
      align-items: center;
      gap: .75rem;
      font-size: .85rem;
      color: var(--text2);
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .dot-done {
      background: #059669;
    }

    .dot-active {
      background: var(--accent);
      animation: pulse-dot 1.4s ease-in-out infinite;
    }

    .dot-pending {
      background: var(--border);
    }

    @keyframes pulse-dot {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: .5;
        transform: scale(.7);
      }
    }

    .status-item.done {
      color: var(--text3);
      text-decoration: line-through;
      text-decoration-color: var(--border);
    }

    .status-item.active {
      color: var(--text);
      font-weight: 600;
    }

    /* ── SOCIAL LINKS ── */
    .social-row {
      display: flex;
      gap: .6rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .social-pill {
      padding: .38rem 1rem;
      border-radius: 50px;
      font-size: .8rem;
      font-weight: 500;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text3);
      text-decoration: none;
      transition: all .2s;
      display: inline-flex;
      align-items: center;
      gap: .35rem;
    }

    .social-pill:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── FOOTER (minimal) ── */
    .foot-strip {
      border-top: 1px solid var(--border);
      padding: 1.25rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: .8rem;
      color: var(--text3);
      background: var(--bg);
      transition: background .4s;
    }

    @media (max-width: 600px) {
      .top-bar {
        padding: 0 1.25rem;
      }

      .foot-strip {
        padding: 1rem 1.25rem;
        flex-direction: column;
        gap: .4rem;
        text-align: center;
      }

      .notify-row {
        flex-direction: column;
      }

      .btn-notify {
        border-radius: 10px;
      }
    }
  </style>
</head>

<body>

  <!-- TOP BAR -->
  <div class="top-bar">
    <a class="nav-logo" href="#">Book<span>ly</span></a>
    <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
    <svg id="theme-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
  </div>

  <!-- MAIN -->
  <main>
    <div class="content">

      <!-- Illustration -->
      <div class="illustration">
        <div class="ring">
          <div class="orbit-dot"></div>
        </div>
        <div class="inner-circle">📚</div>
        <div class="wrench-badge">🔧</div>
      </div>

      <span class="maint-tag">⚙️ Scheduled maintenance</span>

      <h1 class="maint-title">We're writing the<br><em>next chapter.</em></h1>

      <p class="maint-desc">
        Bookly is down for scheduled maintenance while we roll out some exciting upgrades.
        We'll have every story, comment, and chapter back online very soon — promise.
      </p>

      <!-- Countdown -->
      <div class="countdown-wrap">
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-h">02</span>
          <span class="countdown-lbl">Hours</span>
        </div>
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-m">30</span>
          <span class="countdown-lbl">Minutes</span>
        </div>
        <div class="countdown-unit">
          <span class="countdown-num" id="cd-s">00</span>
          <span class="countdown-lbl">Seconds</span>
        </div>
      </div>

      <!-- Progress -->
      <div class="progress-section">
        <div class="progress-header">
          <span class="progress-label">Maintenance progress</span>
          <span class="progress-pct" id="pct-label">68%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" id="prog-fill"></div>
        </div>
      </div>

      <!-- Status checklist -->
      <div class="status-list">
        <div class="status-item done">
          <div class="status-dot dot-done"></div>
          Database backup &amp; migration
        </div>
        <div class="status-item done">
          <div class="status-dot dot-done"></div>
          Search index rebuild
        </div>
        <div class="status-item active">
          <div class="status-dot dot-active"></div>
          Deploying new reading experience
        </div>
        <div class="status-item">
          <div class="status-dot dot-pending"></div>
          Final health checks &amp; testing
        </div>
        <div class="status-item">
          <div class="status-dot dot-pending"></div>
          Back online — see you soon!
        </div>
      </div>

      <!-- Notify form -->
      <div class="notify-card">
        <span class="notify-label">🔔 Get notified the moment we're back</span>
        <div class="notify-row">
          <input class="notify-input" id="notify-email" type="email" placeholder="your@email.com">
          <button class="btn-notify" onclick="submitNotify()">Notify me</button>
        </div>
        <div class="notify-success" id="notify-success">✅ You're on the list! We'll ping you when Bookly is live.</div>
      </div>

      <!-- Social -->
      <p style="font-size:.8rem; color:var(--text3); margin-bottom:.75rem;">Follow updates in the meantime</p>
      <div class="social-row">
        <a href="#" class="social-pill">𝕏 @BooklyApp</a>
        <a href="#" class="social-pill">📸 Instagram</a>
        <a href="#" class="social-pill">💬 Discord</a>
        <a href="mailto:support@bookly.com" class="social-pill">✉️ support@bookly.com</a>
      </div>

    </div>
  </main>

  <!-- MINIMAL FOOTER -->
  <div class="foot-strip">
    <span>© 2026 Bookly — Made with 💜 by <em>Eclipse Network</em></span>
    <span>Expected back by <strong style="color:var(--text2)">June 13, 2026 · 10:30 PM EAT</strong></span>
  </div>

  <script>
    /* ── Theme toggle ── */
  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', isDark ? 'light' : 'dark');
    const icon = document.getElementById('theme-icon');
    if (!isDark) {
      icon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
    } else {
      icon.innerHTML = '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
    }
  }

  /* ── Countdown (2h 30m from page load) ── */
  const end = Date.now() + (2 * 3600 + 30 * 60) * 1000;

  function tick() {
    const diff = Math.max(0, end - Date.now());
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    document.getElementById('cd-h').textContent = String(h).padStart(2, '0');
    document.getElementById('cd-m').textContent = String(m).padStart(2, '0');
    document.getElementById('cd-s').textContent = String(s).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);

  /* ── Progress bar animate in ── */
  const PCT = 68;
  setTimeout(() => {
    document.getElementById('prog-fill').style.width = PCT + '%';
  }, 300);

  /* ── Notify submit ── */
  function submitNotify() {
    const val = document.getElementById('notify-email').value.trim();
    if (!val || !val.includes('@')) {
      document.getElementById('notify-email').focus();
      return;
    }
    document.querySelector('.notify-row').style.display = 'none';
    document.getElementById('notify-success').style.display = 'block';
  }
  </script>

</body>

</html>
