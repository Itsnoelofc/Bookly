<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookly – Goofy Ahh Nigga</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root[data-theme="light"] {
      --bg: #f7f4ff;
      --bg2: #ede8ff;
      --surface: #ffffff;
      --surface2: #f0ebff;
      --border: #d8cdff;
      --text: #1a0f3a;
      --text2: #5a4a8a;
      --text3: #8a78b8;
      --accent: #6c3de8;
      --accent-soft: #9b6ff5;
      --accent-glow: rgba(108, 61, 232, 0.18);
      --card-shadow: 0 4px 24px rgba(108, 61, 232, 0.10);
      --nav-bg: rgba(247, 244, 255, 0.88);
    }

    :root[data-theme="dark"] {
      --bg: #0e0a1f;
      --bg2: #150e2e;
      --surface: #1d1538;
      --surface2: #261d47;
      --border: #352a5a;
      --text: #f0ecff;
      --text2: #b8a8e8;
      --text3: #7860b8;
      --accent: #9b6ff5;
      --accent-soft: #c39dff;
      --accent-glow: rgba(155, 111, 245, 0.25);
      --card-shadow: 0 4px 32px rgba(155, 111, 245, 0.15);
      --nav-bg: rgba(14, 10, 31, 0.90);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      transition: background .4s, color .4s;
      overflow-x: hidden;
    }

    /* ══════════ NAV (exact copy from homepage) ══════════ */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 0 3rem;
      height: 64px;
      background: var(--nav-bg);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
      transition: background .4s, border-color .4s;
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--accent);
      letter-spacing: -0.5px;
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--text);
    }

    .nav-links {
      display: flex;
      gap: .2rem;
      margin-left: 1rem;
    }

    .nav-links a {
      padding: .4rem 1rem;
      border-radius: 8px;
      font-size: .92rem;
      font-weight: 500;
      color: var(--text2);
      text-decoration: none;
      transition: background .2s, color .2s;
    }

    .nav-links a:hover {
      background: var(--surface2);
      color: var(--accent);
    }

    .nav-search {
      flex: 1;
      max-width: 340px;
      margin-left: auto;
      position: relative;
    }

    .nav-search input {
      width: 100%;
      padding: .5rem 1rem .5rem 2.6rem;
      border-radius: 50px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      transition: border-color .2s, background .4s;
      outline: none;
    }

    .nav-search input:focus {
      border-color: var(--accent);
    }

    .nav-search svg {
      position: absolute;
      left: .8rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text3);
      pointer-events: none;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .button-click {
    text-decoration: none;
    }

    .btn-ghost {
      padding: .45rem 1.1rem;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 500;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--text);
      cursor: pointer;
      transition: border-color .2s, color .2s;
    }

    .btn-ghost:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .btn-primary {
      padding: .45rem 1.3rem;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      border: none;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      transition: opacity .2s, transform .15s;
    }

    .btn-primary:hover {
      opacity: .88;
      transform: translateY(-1px);
    }

    .theme-toggle {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text2);
      transition: all .2s;
      flex-shrink: 0;
    }

    .theme-toggle:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ══════════ PAGE BODY ══════════ */
    .page-body {
      padding-top: 64px;
    }

    /* ── HERO BANNER ── */
    .book-hero {
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      padding: 2.5rem 3rem;
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
      transition: background .4s;
      position: relative;
      overflow: hidden;
    }

    .book-hero::before {
      content: '';
      position: absolute;
      top: -100px;
      right: -100px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 65%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* Cover */
    .cover-wrap {
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }

    .book-cover-img {
      width: 180px;
      height: 260px;
      border-radius: 14px;
      background: linear-gradient(145deg, #6c3de8, #a855f7, #ec4899);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      box-shadow: 0 12px 40px var(--accent-glow), 0 4px 12px rgba(0, 0, 0, .15);
      transition: transform .3s;
    }

    .book-cover-img:hover {
      transform: scale(1.03) rotate(-1deg);
    }

    /* Hero info */
    .hero-info {
      flex: 1;
      z-index: 1;
    }

    .original-badge {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      padding: .28rem .85rem;
      border-radius: 50px;
      background: linear-gradient(135deg, var(--accent), #a855f7);
      color: #fff;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
      margin-bottom: .8rem;
      box-shadow: 0 2px 12px var(--accent-glow);
    }

    .original-badge svg {
      flex-shrink: 0;
    }

    .book-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 900;
      color: var(--text);
      line-height: 1.15;
      margin-bottom: .5rem;
    }

    .author-row {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-bottom: 1rem;
    }

    .author-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #a855f7, #ec4899);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .78rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .author-name {
      font-size: .95rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      transition: opacity .2s;
    }

    .author-name:hover {
      opacity: .75;
    }

    /* Stats row */
    .stats-row {
      display: flex;
      align-items: center;
      gap: 1.4rem;
      margin-bottom: 1.2rem;
      flex-wrap: wrap;
    }

    .stat-item {
      display: flex;
      align-items: center;
      gap: .35rem;
      font-size: .88rem;
      color: var(--text2);
      font-weight: 500;
    }

    .stat-item svg {
      color: var(--text3);
    }

    .stat-item strong {
      color: var(--text);
      font-weight: 700;
    }

    /* Format badges */
    .format-row {
      display: flex;
      gap: .6rem;
      margin-bottom: 1.4rem;
      flex-wrap: wrap;
    }

    .format-badge {
      display: flex;
      align-items: center;
      gap: .35rem;
      padding: .32rem .85rem;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-size: .8rem;
      font-weight: 600;
      color: var(--text2);
      transition: border-color .2s, color .2s;
    }

    .format-badge:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* CTA buttons */
    .cta-row {
      display: flex;
      gap: .8rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-start {
      padding: .75rem 2.2rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      border: none;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      box-shadow: 0 4px 20px var(--accent-glow);
      transition: transform .2s, box-shadow .2s, opacity .2s;
      display: flex;
      align-items: center;
      gap: .5rem;
    }

    .btn-start:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px var(--accent-glow);
    }

    .btn-add {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text2);
      cursor: pointer;
      font-size: 1.3rem;
      transition: all .2s;
      font-weight: 300;
    }

    .btn-add:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--surface2);
    }

    .btn-like {
      display: flex;
      align-items: center;
      gap: .4rem;
      padding: .72rem 1.3rem;
      border-radius: 50px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      color: var(--text2);
      cursor: pointer;
      transition: all .2s;
    }

    .btn-like:hover,
    .btn-like.liked {
      border-color: #e879a0;
      color: #e879a0;
      background: rgba(232, 121, 160, .08);
    }

    /* ══════════ CONTENT AREA ══════════ */
    .content-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 3rem;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 2.5rem;
    }

    /* ── TABS ── */
    .tab-bar {
      display: flex;
      border-bottom: 2px solid var(--border);
      margin-bottom: 1.8rem;
      gap: 0;
    }

    .tab-btn {
      padding: .65rem 1.5rem;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      font-weight: 600;
      border: none;
      background: transparent;
      color: var(--text3);
      cursor: pointer;
      position: relative;
      transition: color .2s;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
    }

    .tab-btn::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transition: transform .25s;
    }

    .tab-btn.active {
      color: var(--accent);
    }

    .tab-btn.active::after {
      transform: scaleX(1);
    }

    .tab-btn:hover {
      color: var(--accent);
    }

    /* Tab panels */
    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
      animation: fadeIn .25s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    /* Summary tab */
    .summary-meta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1rem 1.2rem;
      border-radius: 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      margin-bottom: 1.4rem;
      flex-wrap: wrap;
    }

    .sm-item {
      display: flex;
      align-items: center;
      gap: .4rem;
      font-size: .88rem;
      color: var(--text2);
    }

    .sm-item svg {
      color: var(--accent);
    }

    .sm-item strong {
      color: var(--text);
    }

    .status-badge {
      padding: .18rem .7rem;
      border-radius: 50px;
      background: rgba(52, 211, 153, .15);
      color: #059669;
      font-size: .75rem;
      font-weight: 700;
    }

    :root[data-theme="dark"] .status-badge {
      background: rgba(52, 211, 153, .1);
      color: #34d399;
    }

    .tags-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-bottom: 1.5rem;
    }

    .tag-pill {
      padding: .28rem .85rem;
      border-radius: 50px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-size: .78rem;
      color: var(--text2);
      transition: border-color .2s, color .2s;
      cursor: pointer;
    }

    .tag-pill:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .description {
      font-size: .97rem;
      line-height: 1.8;
      color: var(--text2);
      margin-bottom: .8rem;
    }

    .description.clamped {
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .read-more-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--accent);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      padding: 0;
      transition: opacity .2s;
    }

    .read-more-btn:hover {
      opacity: .75;
    }

    /* Ranking strip */
    .ranking-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: .9rem 1.2rem;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      margin-top: 1.5rem;
      cursor: pointer;
      transition: border-color .2s;
    }

    .ranking-strip:hover {
      border-color: var(--accent);
    }

    .rs-left {
      display: flex;
      align-items: center;
      gap: .8rem;
    }

    .rs-rank {
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--accent);
    }

    .rs-tag {
      font-size: .82rem;
      color: var(--text2);
    }

    .rs-tag strong {
      color: var(--text);
    }

    .rs-arrow {
      color: var(--text3);
    }

    /* Parts / chapters tab */
    .parts-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .parts-count {
      font-size: .85rem;
      color: var(--text3);
    }

    .chapter-list {
      display: flex;
      flex-direction: column;
    }

    .chapter-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: .9rem 0;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background .2s;
      border-radius: 0;
      text-decoration: none;
      color: inherit;
    }

    .chapter-item:first-child {
      border-top: 1px solid var(--border);
    }

    .chapter-item:hover {
      background: var(--surface2);
      padding-left: .6rem;
      padding-right: .6rem;
      margin: 0 -.6rem;
      border-radius: 10px;
      border-color: transparent;
    }

    .ch-num-badge {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: var(--surface2);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .78rem;
      font-weight: 700;
      color: var(--text3);
      flex-shrink: 0;
    }

    .chapter-item.current .ch-num-badge {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .ch-item-info {
      flex: 1;
    }

    .ch-item-title {
      font-size: .92rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: .15rem;
    }

    .ch-item-meta {
      font-size: .75rem;
      color: var(--text3);
    }

    .ch-item-right {
      display: flex;
      align-items: center;
      gap: .6rem;
    }

    .ch-locked {
      font-size: .8rem;
      color: var(--text3);
    }

    .ch-new {
      padding: .12rem .5rem;
      border-radius: 50px;
      background: var(--accent);
      color: #fff;
      font-size: .65rem;
      font-weight: 700;
    }

    /* ══════════ RIGHT SIDEBAR ══════════ */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Author card */
    .sidebar-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.3rem;
      transition: background .4s, border-color .4s;
    }

    .sc-title {
      font-size: .72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--text3);
      margin-bottom: 1rem;
      padding-bottom: .5rem;
      border-bottom: 1px solid var(--border);
    }

    .author-card-body {
      display: flex;
      gap: .9rem;
      align-items: center;
    }

    .author-big-avatar {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      flex-shrink: 0;
      background: linear-gradient(135deg, #6c3de8, #a855f7, #ec4899);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      font-weight: 700;
      color: #fff;
    }

    .author-details {
      flex: 1;
    }

    .author-display-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: .15rem;
    }

    .author-handle {
      font-size: .8rem;
      color: var(--accent);
      margin-bottom: .4rem;
    }

    .author-bio {
      font-size: .8rem;
      color: var(--text2);
      line-height: 1.5;
      margin-bottom: .6rem;
    }

    .author-stats-row {
      display: flex;
      gap: 1rem;
    }

    .as-stat {
      display: flex;
      flex-direction: column;
    }

    .as-num {
      font-size: .92rem;
      font-weight: 700;
      color: var(--text);
    }

    .as-lbl {
      font-size: .68rem;
      color: var(--text3);
    }

    .btn-follow {
      width: 100%;
      margin-top: .9rem;
      padding: .5rem;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      font-family: 'DM Sans', sans-serif;
      font-size: .86rem;
      font-weight: 600;
      color: var(--text2);
      cursor: pointer;
      transition: all .2s;
    }

    .btn-follow:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(108, 61, 232, .06);
    }

    .btn-follow.following {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(108, 61, 232, .08);
    }

    /* Related books */
    .related-list {
      display: flex;
      flex-direction: column;
      gap: .8rem;
    }

    .related-item {
      display: flex;
      gap: .8rem;
      align-items: center;
      cursor: pointer;
      padding: .4rem;
      border-radius: 10px;
      transition: background .2s;
      text-decoration: none;
    }

    .related-item:hover {
      background: var(--surface2);
    }

    .rel-cover {
      width: 46px;
      height: 64px;
      border-radius: 8px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .rel-info {
      flex: 1;
      min-width: 0;
    }

    .rel-title {
      font-size: .85rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: .1rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .rel-author {
      font-size: .75rem;
      color: var(--text3);
      margin-bottom: .2rem;
    }

    .rel-tags {
      display: flex;
      gap: .3rem;
      flex-wrap: wrap;
    }

    .rel-tag {
      padding: .1rem .45rem;
      border-radius: 50px;
      background: var(--surface2);
      color: var(--accent);
      font-size: .62rem;
      font-weight: 600;
    }

    /* ══════════ FOOTER (exact copy from homepage) ══════════ */
    footer {
      margin-top: 4rem;
      border-top: 1px solid var(--border);
      padding: 3rem;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
      background: var(--bg);
      transition: background .4s, border-color .4s;
    }

    .footer-brand .nav-logo {
      font-size: 1.4rem;
    }

